# === VPN Control Panel — Конфигурация ===

# Порт, на котором будет работать панель
PORT=3000

# Строка подключения к PostgreSQL
# Формат: postgresql://пользователь:пароль@хост:порт/имя_базы
DATABASE_URL=postgresql://vpn_panel:your_password_here@localhost:5432/vpn_panel

# Секретный ключ для JWT-токенов (сгенерируйте уникальный)
# Можно сгенерировать командой: openssl rand -hex 32
JWT_SECRET=change_me_to_random_secret

# Режим работы (production / development)
NODE_ENV=production
