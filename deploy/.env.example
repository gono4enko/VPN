# === База данных ===
POSTGRES_USER=vpn
# Используйте только буквы, цифры и подчёркивания (без @, #, %, / и пробелов)
POSTGRES_PASSWORD=changeme_strong_password_here
POSTGRES_DB=vpn_panel
# DATABASE_URL формируется автоматически в docker-compose.yml из переменных выше.
# Если вы запускаете приложение без Docker Compose, укажите URL вручную:
# DATABASE_URL=postgresql://vpn:your_password@localhost:5432/vpn_panel

# === Приложение ===
# Порт, на котором панель будет доступна снаружи (по умолчанию 3000)
APP_PORT=3000

# Секрет для JWT-токенов (сгенерируйте длинную случайную строку)
JWT_SECRET=your_jwt_secret_here_change_me

# === Учётные данные администратора ===
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme_admin_password

# === Настройки VPN-сервера (VLESS/Reality) ===
OFFICE_IP=your_server_ip
OFFICE_PORT=443
OFFICE_SNI=example.com
OFFICE_PUBLIC_KEY=your_public_key_here
OFFICE_SHORT_ID=your_short_id_here
